{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://vyaparx-production.up.railway.app",
        "EXPO_PUBLIC_REQUEST_ORIGIN": "https://vyaparx.online",
        "EXPO_PUBLIC_PASSKEY_DOMAIN": "vyaparx.online"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://vyaparx-production.up.railway.app",
        "EXPO_PUBLIC_REQUEST_ORIGIN": "https://vyaparx.online",
        "EXPO_PUBLIC_PASSKEY_DOMAIN": "vyaparx.online"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
